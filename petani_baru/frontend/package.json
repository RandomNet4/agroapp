{
  "name": "agro-tani",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "dev:backend": "npm --prefix ../backend run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prisma:studio": "npm --prefix ../backend run prisma:studio",
    "prisma:seed": "npm --prefix ../backend run prisma:seed",
    "prisma:migrate": "npm --prefix ../backend run prisma:migrate"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
