    "jsonwebtoken": "^9.0.3",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.24",
    "nodemon": "^3.1.0",
    "prisma": "^6.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
