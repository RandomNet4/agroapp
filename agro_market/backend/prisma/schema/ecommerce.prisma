// ─── Ecommerce Schema: Toko, Produk, Pesanan, Keranjang, dll. ───────────────────
// PostgreSQL Schema: "ecommerce"

// ─── Toko ───────────────────────────────────────────────────────────────────

model Toko {
  id               String       @id @default(uuid())
  penjualId        String       @unique
  nama             String
  slug             String       @unique
  kabupaten        String
  wilayah          String
  deskripsi        String?
  alamat           String
  telepon          String
  jamOperasional   String?
  fotoUrl          String?
  bannerUrl        String?
  komoditasUnggulan String[]
  status           StatusToko   @default(PENDING)
  lat              Float?
  lng              Float?
  areaCakupanKota  String[]     @default([])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  penjual        ProfilPenjual        @relation(fields: [penjualId], references: [id], onDelete: Cascade)
  produk         ProdukEcom[]
  inventaris     InventarisToko[]
  pengajuanStok  PengajuanStokToko[]
  courierStaffId String?
  kurirStaffs    Pengguna[]           @relation("StoreCouriers")
  pesananEcoms   PesananEcom[]
  priceConfig    KonfigurasiHargaToko?
  riwayatMargin  RiwayatMargin[]
  transaksiKeuntungan TransaksiKeuntungan[]
  batchPengiriman     BatchPengiriman[]

  @@map("stores")
  @@schema("ecommerce")
}

enum StatusToko {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED

  @@schema("ecommerce")
}

// ─── Kategori ────────────────────────────────────────────────────────────────

model KategoriToko {
  id            String         @id @default(uuid())
  nama          String         @unique
  icon          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  produk        ProdukEcom[]
  masterProduk  MasterProduk[]

  @@map("store_categories")
  @@schema("ecommerce")
}

// ─── Produk ─────────────────────────────────────────────────────────────────

model ProdukEcom {
  id                String            @id @default(uuid())
  tokoId            String
  kategoriId        String
  masterProdukId    String?           // null jika produk mandiri (bukan dari gudang)
  produkGudangId    String?           // Reference ke ProdukGudang di DB Gudang
  nama              String            // Nama asli dari Master (snapshot) atau nama produk mandiri
  namaEtalase       String?           // Nama custom etalase (null = pakai nama master)
  deskripsi         String
  harga             Float
  hargaAsli         Float?
  satuan            String
  beratGram         Int               @default(1000)
  stok              Int               @default(0)
  gambarUrl         String?
  fotoLainnya       String[]          @default([])
  nutrisi           String?
  asalKebun         String?
  tanggalPanen      DateTime?
  estimasiSegarHari Int               @default(3)
  diskonPersen      Int?
  status            StatusProdukEcom  @default(ACTIVE)
  hargaBeli         Float?            // Harga Pokok Penjualan (HPP) / Harga Beli dari Gudang
  marginPersen      Float?            // Override margin default toko (null = gunakan default)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  toko            Toko                  @relation(fields: [tokoId], references: [id], onDelete: Cascade)
  kategori        KategoriToko          @relation(fields: [kategoriId], references: [id])
  masterProduk    MasterProduk?         @relation(fields: [masterProdukId], references: [id])
  itemKeranjang   ItemKeranjangEcom[]
  itemPesanan     ItemPesananEcom[]
  stockHistory    RiwayatStokProduk[]
  ulasan          UlasanProdukEcom[]
  inventarisToko  InventarisToko[]
  riwayatMargin   RiwayatMargin[]
  stokMasuk       StokMasukProduk[]
  transaksiKeuntungan TransaksiKeuntungan[]

  // Varian kemasan
  varian          VarianKemasan[]

  @@index([tokoId])
  @@index([kategoriId])
  @@index([status])
  @@map("ecom_products")
  @@schema("ecommerce")
}

// ─── Master Produk (Dikelola Admin E-commerce) ─────────────────────────

model MasterProduk {
  id                String            @id @default(uuid())
  nama              String            @unique  // "Jagung Frozen" — SATU-SATUNYA sumber kebenaran
  slug              String            @unique  // "jagung-frozen"
  deskripsi         String                     // Deskripsi standar untuk semua seller
  kategoriId        String
  satuan            String            @default("kg")
  beratGram         Int               @default(1000)
  gambarUrl         String?                    // Foto produk standar
  fotoLainnya       String[]          @default([])
  nutrisi           String?                    // Info nutrisi standar
  estimasiSegarHari Int               @default(3)
  isActive          Boolean           @default(true)
  
  // Aturan penamaan etalase
  allowCustomName     Boolean         @default(true)  // Boleh custom atau tidak
  namaWajibMengandung String?         // Kata kunci yang HARUS ada di nama custom
  
  // Kode komoditas global lintas-layanan (WORTEL, CABAI_MERAH, dll)
  kodeKomoditasGlobal String?  @unique
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  kategori          KategoriToko          @relation(fields: [kategoriId], references: [id])
  produkEcoms       ProdukEcom[]          // Semua produk seller yang merujuk ke master ini
  mappingGudang     MappingProdukGudang[]  // Mapping ke produk gudang

  @@map("master_products")
  @@schema("ecommerce")
}

// ─── Mapping Master Produk ↔ Produk Gudang ────────────────────────────

model MappingProdukGudang {
  id              String   @id @default(uuid())
  masterProdukId  String
  produkGudangId  String   // Reference ke ProdukGudang di database GUDANG
  gudangId        String   // Reference ke Gudang di database GUDANG
  gudangNama      String?  // Snapshot nama gudang
  createdAt       DateTime @default(now())

  masterProduk    MasterProduk @relation(fields: [masterProdukId], references: [id], onDelete: Cascade)
  
  @@unique([masterProdukId, produkGudangId])
  @@map("master_product_warehouse_mappings")
  @@schema("ecommerce")
}



// ─── Riwayat Stok Produk ───────────────────────────────────────────────────

model RiwayatStokProduk {
  id         String          @id @default(uuid())
  produkId   String
  penggunaId String
  tipe       TipePerubahanStok
  kuantitas  Int
  stokAkhir  Int
  catatan    String?
  pesananId  String?
  createdAt  DateTime        @default(now())

  produk   ProdukEcom @relation(fields: [produkId], references: [id], onDelete: Cascade)
  pengguna Pengguna   @relation(fields: [penggunaId], references: [id])
  pesanan  PesananEcom? @relation(fields: [pesananId], references: [id])

  @@map("product_stock_history")
  @@schema("ecommerce")
}

enum TipePerubahanStok {
  IN
  OUT
  ADJUSTMENT

  @@schema("ecommerce")
}

enum StatusProdukEcom {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK

  @@schema("ecommerce")
}

// ─── Keranjang ────────────────────────────────────────────────────────────────────

model KeranjangEcom {
  id         String   @id @default(uuid())
  konsumenId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  konsumen Pengguna            @relation(fields: [konsumenId], references: [id], onDelete: Cascade)
  item     ItemKeranjangEcom[]

  @@map("ecom_carts")
  @@schema("ecommerce")
}

model ItemKeranjangEcom {
  id              String         @id @default(uuid())
  keranjangId     String
  produkId        String
  varianKemasanId String?
  jumlah          Int            @default(1)
  createdAt       DateTime       @default(now())

  keranjang       KeranjangEcom  @relation(fields: [keranjangId], references: [id], onDelete: Cascade)
  produk          ProdukEcom     @relation(fields: [produkId], references: [id])
  varianKemasan   VarianKemasan? @relation(fields: [varianKemasanId], references: [id], onDelete: SetNull)

  @@unique([keranjangId, produkId, varianKemasanId])
  @@map("ecom_cart_items")
  @@schema("ecommerce")
}

// ─── Pesanan ───────────────────────────────────────────────────────────────────

model PesananEcom {
  id          String            @id @default(uuid())
  konsumenId  String
  totalHarga  Float
  ongkir      Float             @default(0)
  metodeBayar String
  alamatKirim String
  jadwalKirim  DateTime?
  isGrosir     Boolean           @default(false)
  status       StatusPesananEcom @default(MENUNGGU_BAYAR)
  diprosesOleh String            @default("TOKO") // "TOKO" atau "GUDANG"
  gudangId     String?
  tokoId       String?
  catatan      String?
  jarakPengirimanKm Float?
  isFallbackDistance Boolean @default(false)
  metodeKirim  String?           @default("LOKAL")
  paymentId    String?
  paymentUrl   String?
  fotoSebelumKirimUrl String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  konsumen     Pengguna               @relation(fields: [konsumenId], references: [id])
  item      ItemPesananEcom[]
  pengiriman PengirimanPesananEcom?
  ulasan    UlasanProdukEcom[]
  riwayatStok RiwayatStokProduk[]
  toko        Toko?                   @relation(fields: [tokoId], references: [id])
  transaksiKeuntungan TransaksiKeuntungan[]

  @@index([konsumenId])
  @@index([status])
  @@index([tokoId])
  @@map("ecom_orders")
  @@schema("ecommerce")
}

model ItemPesananEcom {
  id              String               @id @default(uuid())
  pesananId       String
  produkId        String
  varianKemasanId String?
  jumlah          Int
  harga           Float

  // Custom Grosir fields
  isCustomGrosir  Boolean              @default(false)
  ukuranCustomKg  Float?
  totalKg         Float?

  pesanan         PesananEcom          @relation(fields: [pesananId], references: [id], onDelete: Cascade)
  produk          ProdukEcom           @relation(fields: [produkId], references: [id])
  varianKemasan   VarianKemasan?       @relation(fields: [varianKemasanId], references: [id], onDelete: SetNull)
  ulasan          UlasanProdukEcom?
  transaksiKeuntungan TransaksiKeuntungan?

  @@index([pesananId])
  @@index([produkId])
  @@map("ecom_order_items")
  @@schema("ecommerce")
}

enum StatusPesananEcom {
  MENUNGGU_KONFIRMASI_SELLER
  MENUNGGU_BAYAR
  DIPROSES
  DIKIRIM
  SELESAI
  DITUTUP   // Seller sudah verifikasi & tutup pesanan
  DIBATALKAN

  @@schema("ecommerce")
}

// ─── Pengiriman Pesanan ──────────────────────────────────────────────────────────

model PengirimanPesananEcom {
  id              String         @id @default(uuid())
  pesananId       String         @unique
  kurirPenggunaId String?
  kurirNama       String?
  kurirTelepon    String?
  status          StatusPengiriman @default(PREPARING)
  catatan         String?
  trackingHistory Json           @default("[]")
  buktiKirimFoto      String[]                         // JSON array of photo URLs
  buktiKirimCatatan   String?                          // Delivery notes
  buktiKirimWaktu     DateTime?                        // When proof was submitted
  buktiKirimLat       Float?                           // GPS latitude
  buktiKirimLng       Float?                           // GPS longitude
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  pesanan PesananEcom @relation(fields: [pesananId], references: [id], onDelete: Cascade)

  @@map("ecom_order_shippings")
  @@schema("ecommerce")
}

enum StatusPengiriman {
  PREPARING
  LOADING
  PICKUP_CONFIRMATION
  PICKED_UP
  IN_TRANSIT
  ARRIVED

  @@schema("ecommerce")
}


// ─── Alamat Konsumen ────────────────────────────────────────────────────────

model AlamatKonsumen {
  id         String   @id @default(uuid())
  konsumenId String
  label      String
  penerima   String?
  alamat     String
  kota       String
  provinsi   String
  kecamatan  String?
  kelurahan  String?
  kodePos    String?
  telepon    String?
  isDefault  Boolean  @default(false)
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  konsumen Pengguna @relation(fields: [konsumenId], references: [id], onDelete: Cascade)

  @@map("customer_addresses")
  @@schema("ecommerce")
}

// ─── Notifikasi ────────────────────────────────────────────────────────────

enum TipeNotifikasi {
  PESANAN
  PESANAN_BARU
  PEMBAYARAN
  ULASAN
  AKUN
  PROMO
  SISTEM
  STOK
  TOKO
  GROSIR
  LAPORAN
  BROADCAST
  TUGAS_BARU
  TUGAS
  CHAT
  ESKALASI
  VERIFIKASI_TOKO
  VERIFIKASI_B2B

  @@schema("ecommerce")
}

model Notifikasi {
  id        String         @id @default(uuid())
  penggunaId String
  judul     String
  pesan     String
  tipe      TipeNotifikasi
  isRead    Boolean        @default(false)
  data      Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  pengguna Pengguna @relation(fields: [penggunaId], references: [id], onDelete: Cascade)

  @@index([penggunaId, isRead])
  @@index([penggunaId, createdAt])
  @@index([tipe])
  @@map("notifications")
  @@schema("ecommerce")
}

// ─── Konfigurasi Pengiriman ─────────────────────────────────────────────────────────

model KonfigurasiPengiriman {
  id              String   @id @default(uuid())
  jarakDasarKm    Float    @default(5.0)
  hargaDasar      Float    @default(10000)
  hargaPerKmExtra Float    @default(2000)
  beratDasarKg    Float    @default(5.0)
  hargaPerKgExtra Float    @default(5000)
  jarakMaksKm     Float?   @default(50.0)
  gratisBawahKm   Float    @default(5.0)
  ongkirFlat      Float    @default(15000)
  gratisAboveKg   Float    @default(300)
  ekspedisiBaseCost Float  @default(20000)
  ekspedisiPerKgCost Float @default(8000)
  ekspedisiPerKmCost Float @default(1500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("shipping_configs")
  @@schema("ecommerce")
}

// ─── Ulasan Produk ──────────────────────────────────────────────────────────

model UlasanProdukEcom {
  id            String              @id @default(uuid())
  itemPesananId String              @unique
  produkId      String
  pesananId     String
  penggunaId    String
  rating        Int
  ulasan        String?             @db.Text
  fotoUrl       String?
  isHidden      Boolean             @default(false)
  alasanLaporan String?
  dilaporkanPada DateTime?
  statusLaporan StatusLaporanUlasan?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  itemPesanan ItemPesananEcom @relation(fields: [itemPesananId], references: [id], onDelete: Cascade)
  produk      ProdukEcom      @relation(fields: [produkId], references: [id], onDelete: Cascade)
  pesanan     PesananEcom     @relation(fields: [pesananId], references: [id], onDelete: Cascade)
  pengguna    Pengguna        @relation(fields: [penggunaId], references: [id], onDelete: Cascade)

  @@map("ecom_product_reviews")
  @@schema("ecommerce")
}

enum StatusLaporanUlasan {
  REPORTED
  TAKEDOWN_APPROVED
  TAKEDOWN_REJECTED

  @@schema("ecommerce")
}

// ─── Inventaris dan Stok Toko Baru ─────────────────────────────────────────

model InventarisToko {
  id             String     @id @default(uuid())
  tokoId         String
  produkId       String
  stokFisikKg    Float      @default(0)
  stokTersediaKg Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  toko   Toko       @relation(fields: [tokoId], references: [id], onDelete: Cascade)
  produk ProdukEcom @relation(fields: [produkId], references: [id], onDelete: Cascade)

  @@unique([tokoId, produkId])
  @@map("ecom_store_inventory")
  @@schema("ecommerce")
}

model PengajuanStokToko {
  id             String              @id @default(uuid())
  tokoId         String
  gudangId       String
  status         StatusPengajuanStok @default(DIAJUKAN)
  modePengemasan ModePengemasan      @default(DEFAULT)
  catatan        String?
  isPesananGrosir Boolean            @default(false)
  alamatKirim     String?
  lat             Float?
  lng             Float?
  konsumenId      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  toko   Toko                @relation(fields: [tokoId], references: [id])
  items  ItemPengajuanStok[]
  stokMasuk StokMasukProduk[]

  @@map("ecom_store_stock_requests")
  @@schema("ecommerce")
}

model ItemPengajuanStok {
  id               String     @id @default(uuid())
  pengajuanId      String
  produkGudangId   String     // Reference ke ProdukGudang.id (di database GUDANG)
  namaProduk       String     // Snapshot nama produk saat pengajuan
  varianProduk     String?    // Snapshot varian produk saat pengajuan (e.g. "Frozen")
  satuan           String     // Snapshot satuan (kg, ton, dll)
  hargaGudang      Float      // Snapshot harga gudang saat pengajuan
  jumlahPermintaan Float
  jumlahDisetujui  Float?
  ukuranKemasanKg  Float?
  jumlahKemasan    Int?

  pengajuan     PengajuanStokToko          @relation(fields: [pengajuanId], references: [id], onDelete: Cascade)
  kemasanDetail ItemPengajuanStokKemasan[]
  // Note: Tidak ada foreign key ke ProdukGudang karena beda database
  // produkGudangId disimpan sebagai string reference saja
  stokMasuk StokMasukProduk[]

  @@map("ecom_store_stock_request_items")
  @@schema("ecommerce")
}

enum ModePengemasan {
  DEFAULT
  CUSTOM

  @@schema("ecommerce")
}

model ItemPengajuanStokKemasan {
  id                  String            @id @default(uuid())
  itemPengajuanStokId String
  ukuranKg            Float             // 1.0 atau 2.5
  jumlahKemasan       Int

  itemPengajuanStok   ItemPengajuanStok @relation(fields: [itemPengajuanStokId], references: [id], onDelete: Cascade)

  @@unique([itemPengajuanStokId, ukuranKg])
  @@map("ecom_store_stock_request_item_packages")
  @@schema("ecommerce")
}

model KonfigurasiHargaToko {
  id                  String   @id @default(uuid())
  tokoId              String   @unique
  marginDefaultPersen Float    @default(15.0) // Default margin 15% untuk seller
  marginMaxPersen     Float    @default(30.0) // Batas maksimum margin default 30% diatur oleh admin
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  toko Toko @relation(fields: [tokoId], references: [id], onDelete: Cascade)

  @@map("ecom_store_price_configs")
  @@schema("ecommerce")
}

enum StatusPengajuanStok {
  DIAJUKAN
  DIPROSES
  DIKIRIM
  KONFIRMASI_DITERIMA
  SELESAI
  DITOLAK

  @@schema("ecommerce")
}

// ─── Riwayat Margin (Log Perubahan Margin) ─────────────────────────────────

model RiwayatMargin {
  id              String   @id @default(uuid())
  tokoId          String
  produkId        String?  // Jika null, berarti ini perubahan default margin toko
  marginLama      Float?
  marginBaru      Float
  diubahOlehPeran String   // "ADMIN" atau "SELLER"
  diubahOlehId    String
  keterangan      String?
  createdAt       DateTime @default(now())

  toko   Toko        @relation(fields: [tokoId], references: [id], onDelete: Cascade)
  produk ProdukEcom? @relation(fields: [produkId], references: [id], onDelete: Cascade)

  @@map("ecom_margin_history")
  @@schema("ecommerce")
}

// ─── FIFO Stock Tracking & Profit Report ─────────────────────────────────

// ─── Stok Masuk Produk (FIFO Batches) ─────────────────────────────────

model StokMasukProduk {
  id                    String   @id @default(uuid())
  produkId              String
  pengajuanStokId       String
  itemPengajuanStokId   String
  varianKemasanId       String?
  ukuranKemasanKg       Float?
  jumlahKemasanMasuk    Int?
  jumlahKemasanTersisa  Int?
  jumlahMasuk           Float    // Jumlah stok yang masuk (kg)
  jumlahTersisa         Float    // Sisa stok yang belum terjual (kg)
  hargaBeli             Float    // Harga beli per kg dari gudang
  tanggalMasuk          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  produk                ProdukEcom           @relation(fields: [produkId], references: [id], onDelete: Cascade)
  pengajuanStok         PengajuanStokToko    @relation(fields: [pengajuanStokId], references: [id])
  itemPengajuanStok     ItemPengajuanStok    @relation(fields: [itemPengajuanStokId], references: [id])
  varianKemasan         VarianKemasan?       @relation(fields: [varianKemasanId], references: [id], onDelete: SetNull)
  transaksiKeuntungan   TransaksiKeuntunganBatch[]

  @@index([produkId, jumlahTersisa])
  @@index([produkId, tanggalMasuk])
  @@index([produkId, varianKemasanId, jumlahKemasanTersisa])
  @@map("ecom_product_stock_in")
  @@schema("ecommerce")
}

// ─── Transaksi Keuntungan (Profit Transactions) ─────────────────────────

model TransaksiKeuntungan {
  id                String   @id @default(uuid())
  itemPesananId     String   @unique
  pesananId         String
  produkId          String
  tokoId            String
  jumlahTerjual     Float    // Jumlah yang terjual (kg)
  hargaJual         Float    // Harga jual per kg
  hargaBeli         Float    // Harga beli rata-rata (FIFO weighted)
  totalHargaBeli    Float    // Total harga beli (FIFO calculation)
  statusPesanan     StatusPesananEcom
  tanggalTransaksi  DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  itemPesanan       ItemPesananEcom @relation(fields: [itemPesananId], references: [id], onDelete: Cascade)
  pesanan           PesananEcom     @relation(fields: [pesananId], references: [id])
  produk            ProdukEcom      @relation(fields: [produkId], references: [id])
  toko              Toko            @relation(fields: [tokoId], references: [id])
  batchDetails      TransaksiKeuntunganBatch[]

  @@index([produkId, tanggalTransaksi])
  @@index([tokoId, tanggalTransaksi])
  @@index([pesananId])
  @@map("ecom_profit_transactions")
  @@schema("ecommerce")
}

// ─── Detail Batch per Transaksi Keuntungan ─────────────────────────────

model TransaksiKeuntunganBatch {
  id                    String   @id @default(uuid())
  transaksiKeuntunganId String
  stokMasukId           String
  jumlahDigunakan       Float    // Berapa kg dari batch ini yang digunakan
  hargaBeli             Float    // Harga beli dari batch ini
  createdAt             DateTime @default(now())

  transaksiKeuntungan   TransaksiKeuntungan @relation(fields: [transaksiKeuntunganId], references: [id], onDelete: Cascade)
  stokMasuk             StokMasukProduk     @relation(fields: [stokMasukId], references: [id])

  @@index([transaksiKeuntunganId])
  @@map("ecom_profit_transaction_batches")
  @@schema("ecommerce")
}

model VarianKemasan {
  id              String   @id @default(uuid())
  produkId        String
  ukuranKg        Float    // 1.0, 2.5, 10.0
  biayaTambahan   Float    @default(0) // Biaya ekstra jika milih kemasan eceran/kecil
  stokKemasan     Int      @default(0)
  sku             String?  // SKU unik per varian
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  produk          ProdukEcom @relation(fields: [produkId], references: [id], onDelete: Cascade)
  itemKeranjang   ItemKeranjangEcom[]
  itemPesanan     ItemPesananEcom[]
  stokMasuk       StokMasukProduk[]

  @@unique([produkId, ukuranKg])
  @@map("ecom_product_packaging_variants")
  @@schema("ecommerce")
}

// ─── Batch Pengiriman (Delivery Batching System) ─────────────────────────

model BatchPengiriman {
  id                  String       @id @default(uuid())
  tokoId              String
  kurirPenggunaId     String?
  kodeResi            String       @unique  // "BATCH-20260609-PAGI-001"
  tipeBatch           TipeBatch             // PAGI, SIANG
  tanggal             DateTime              // Tanggal pengiriman
  status              StatusBatch  @default(MENUNGGU)
  totalPesanan        Int          @default(0)
  totalBeratKg        Float        @default(0)
  estimasiJarakKm     Float?
  estimasiDurasiMenit Int?
  ruteOptimal         Json?                 // Ordered array of waypoints from OSRM
  catatanKurir        String?
  mulaiKirim          DateTime?
  selesaiKirim        DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  toko   Toko                  @relation(fields: [tokoId], references: [id], onDelete: Cascade)
  items  ItemBatchPengiriman[]

  @@index([tokoId, tanggal])
  @@index([kurirPenggunaId, tanggal])
  @@map("delivery_batches")
  @@schema("ecommerce")
}

model ItemBatchPengiriman {
  id         String @id @default(uuid())
  batchId    String
  pesananId  String @unique   // Setiap pesanan hanya boleh masuk 1 batch
  urutanKe   Int              // Urutan pengiriman dalam batch (1, 2, 3, ...)
  lat        Float?           // Koordinat tujuan
  lng        Float?
  alamat     String?          // Snapshot alamat kirim
  penerima   String?          // Snapshot nama penerima
  status     StatusItemBatch  @default(MENUNGGU)

  batch  BatchPengiriman @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, urutanKe])
  @@map("delivery_batch_items")
  @@schema("ecommerce")
}

enum TipeBatch {
  PAGI
  SIANG

  @@schema("ecommerce")
}

enum StatusBatch {
  MENUNGGU          // Belum di-assign ke kurir
  SIAP_KIRIM        // Sudah di-assign, menunggu kurir mulai
  DALAM_PERJALANAN  // Kurir sedang mengirim batch ini
  SELESAI           // Semua pesanan dalam batch terkirim

  @@schema("ecommerce")
}

enum StatusItemBatch {
  MENUNGGU    // Belum dikirim
  DIKIRIM     // Sedang dikirim (kurir sedang menuju)
  TERKIRIM    // Sudah sampai

  @@schema("ecommerce")
}

// ─── Banner Promo (Home Page) ────────────────────────────────────────────────
model BannerPromo {
  id        String   @id @default(uuid())
  judul     String
  subjudul  String?
  imageUrl  String?
  gradient  String?
  linkUrl   String?
  urutan    Int      @default(0)
  isAktif   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ecom_banner_promos")
  @@schema("ecommerce")
}
